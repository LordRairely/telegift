# Токен от BotFather (в Telegram)
BOT_TOKEN=ваштелеграмтокен

# Yandex Cloud (для YandexGPT)
# Укажите либо API_KEY, либо IAM_TOKEN с FOLDER_ID
YANDEX_API_KEY=ваш_api_ключ_яндекс
YANDEX_FOLDER_ID=ваш_folder_id_яндекс

# Ссылка на PDF/страницу политики обработки персональных данных
PRIVACY_POLICY_URL=https://example.com/privacy

# Администратор и пользователи без лимита загрузок
ADMIN_USERNAME=admin_username
ADMIN_DIALOG_URL=https://t.me/admin_username
UNLIMITED_UPLOAD_USERNAMES=admin_username

# PostgreSQL
POSTGRES_DB=telegift
POSTGRES_USER=telegift
POSTGRES_PASSWORD=telegift
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://telegift:telegift@localhost:5432/telegift
