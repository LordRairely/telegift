# Используем официальный легковесный образ Python
FROM python:3.11-slim

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем только файл зависимостей, чтобы кэшировать этот слой
COPY requirements.txt .

# Устанавливаем зависимости без сохранения кэша установщика (для экономии места)
RUN pip install --no-cache-dir -r requirements.txt

# Копируем весь оставшийся код в контейнер
COPY . .

# Команда по умолчанию для запуска бота
CMD ["python", "bot.py"]
